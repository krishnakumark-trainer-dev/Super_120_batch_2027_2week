class Solution:
    def numberOfSubstrings(self, s: str) -> int:
        hash_map = {'a':0,'b':0,'c':0}
        l = 0
        res = 0
        for r in range(len(s)):
            hash_map[s[r]] = hash_map.get(s[r],0)+1
            while hash_map['a'] and hash_map['b'] and hash_map['c']:
                res+= len(s)-r 
                hash_map[s[l]]-=1
                l+=1
        return  res
                
