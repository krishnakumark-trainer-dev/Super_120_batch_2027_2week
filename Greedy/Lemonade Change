class Solution(object):
    def lemonadeChange(self, bills):
        
        five, ten = 0,0 
        for bill in bills:
            if bill == 5:
                five+=1
                continue 
            if bill == 10:
                ten+=1
                
            
            if bill == 10:
                if five:  five-=1
                else: return False
            else:
                if ten and five:
                    ten-=1
                    five-=1
                elif five>=3:
                    five-=3
                else:
                    return  False
        return True
                
            
