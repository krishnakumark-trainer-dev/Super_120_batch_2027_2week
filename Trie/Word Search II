
class trie_node:
    def __init__(self):
        self.child = {}
        self.is_end = False

    def add_word(self,word):
        cur = self
        for w in word:
            if w not in cur.child:
                cur.child[w] = trie_node()
            cur = cur.child[w]
        cur.is_end = True

class Solution:
    def findWords(self, board: List[List[str]], words: List[str]) -> List[str]:
        root = trie_node()
        for w in words:
            root.add_word(w)


        row , col = len(board) , len(board[0])
        visited , res = set() , set()

        def backtrack(r,c,path,root):
            if r<0 or c<0 or r == row or c == col or (r,c) in visited or board[r][c] not in root.child:
                return
            visited.add((r,c))
            root = root.child[board[r][c]]
            path += board[r][c]
            if root.is_end:
                res.add(path)
                
                
            backtrack(r-1,c,path,root)
            backtrack(r, c-1, path, root)
            backtrack(r + 1, c, path, root)
            backtrack(r , c+1, path, root)
            visited.remove((r,c))
            



        for r in range(row):
            for c in range(col):
                backtrack(r,c,"",root)
        return list(res)


