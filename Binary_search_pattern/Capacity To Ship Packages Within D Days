

class Solution:
    def shipWithinDays(self, weights: List[int], days: int) -> int:
        
        def checker(max_cap):
            cap = 0
            day = 1
            for w in weights:
                cap = cap+ w 
                if cap> max_cap:
                    day +=1
                    cap = w 
                    if day > days:
                        return False
            return True
                    
        
        l , r = max(weights) , sum(weights)
        res = 0
        while l<=r:
            mid = (l+r)//2
            if checker(mid):
                res = mid
                r = mid - 1 
            else: l = mid+1
        return res
                
        
        
