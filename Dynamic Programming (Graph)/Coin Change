class Solution(object):
    def coinChange(self, coins, amount):
        dp = [float('inf')]*(amount+1)
        dp[0]= 0
        for amt in range(1,amount+1):
            for c in coins:
                if amt-c >=0:
                    dp[amt] = min(dp[amt], dp[amt - c] + 1) 
        return -1 if dp[amount] == float('inf') else dp[amount]
