class Solution(object):
    def singleNumber(self, nums):
        ans = 0

        for i in range(32):
            count = 0

            for num in nums:
                if (num >> i) & 1:
                    count += 1

            if count % 3:
                if i == 31:
                    ans -= (1 << 31)
                else:
                    ans |= (1 << i)

        return ans
