class Solution:
    def subarraySum(self, nums: List[int], k: int) -> int:
        hash_map = {0 : 1}
        prefix_sum  = 0
        res = 0
        for n in nums :
            prefix_sum += n
            temp = prefix_sum - k
            res += hash_map.get(temp,0)
            hash_map[prefix_sum] = hash_map.get(prefix_sum,0)+1
        return res








